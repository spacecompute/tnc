FROM ubuntu:25.04

#--- PROXY CONFIG (if needed)
ARG MAVEN_HTTPS_PROXY
ARG HTTPS_PROXY
ARG HTTP_PROXY
ARG NO_PROXY
ARG DEPLOYMENT_ENVIRO

ENV MAVEN_HTTPS_PROXY=${MAVEN_HTTPS_PROXY}
ENV HTTPS_PROXY=${HTTPS_PROXY}
ENV HTTP_PROXY=${HTTP_PROXY}
ENV NO_PROXY=${NO_PROXY}
ENV DEPLOYMENT_ENVIRO=${DEPLOYMENT_ENVIRO}

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        netcat-traditional netcat-openbsd iputils-ping \
        git jq tmux tree vim less curl wget ca-certificates tar gzip gosu acl && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

#--- Specifics
# Install nvm and node
ENV NVM_VERSION=v0.40.5
ENV NVM_URL=https://raw.githubusercontent.com/nvm-sh/nvm/${NVM_VERSION}/install.sh
ENV NVM_DIR=/opt/nvm
RUN mkdir -p $NVM_DIR

ENV NODE_VERSION=v24.18.0
ENV NODE_PATH=$NVM_DIR/versions/node/${NODE_VERSION}/bin
ENV PATH=${NVM_DIR}:${NODE_PATH}:${PATH}

WORKDIR /opt
RUN curl -o- ${NVM_URL} | bash
RUN . ${NVM_DIR}/nvm.sh && nvm install ${NODE_VERSION}

# Clone and build openmct-yamcs
ARG GIT_URL=https://github.com/akhenry/openmct-yamcs.git
ARG GIT_COMMIT=master

ENV GIT_URL=${GIT_URL}
ENV GIT_COMMIT=${GIT_COMMIT}

RUN git clone --recurse-submodules -b ${GIT_COMMIT} -j2 ${GIT_URL} openmct

WORKDIR /opt/openmct

RUN ${NODE_PATH}/npm install -loglevel verbose
RUN ${NODE_PATH}/npm run build:example:master -loglevel verbose

# Default config files (missions override via volume mount)
COPY index.js /opt/openmct/example/index.js
COPY webpack.dev.mjs /opt/openmct/.webpack/webpack.dev.mjs

#--- SHARED GROUP (cross-service volume access; name from mission, GID always 10000)
ARG MISSION_SC=mission-sc
ARG SHARED_GID=10000

RUN if getent group ${SHARED_GID} >/dev/null 2>&1; then \
        groupmod -n ${MISSION_SC} $(getent group ${SHARED_GID} | cut -d: -f1); \
    else \
        groupadd -r -g ${SHARED_GID} ${MISSION_SC}; \
    fi

ENV SHARED_GID=${SHARED_GID}

#--- SERVICE USER (override UID/GID at build time to match host or orchestrator)
ARG SERVICE_UID=10002
ARG SERVICE_GID=10002

ENV SERVICE_UID=${SERVICE_UID}
ENV SERVICE_GID=${SERVICE_GID}

RUN groupadd -r -g ${SERVICE_GID} openmct && \
    useradd -r -u ${SERVICE_UID} -g openmct -G ${MISSION_SC} -d /opt/openmct -s /sbin/nologin openmct && \
    mkdir -p /opt/openmct/example/displays && \
    chown -R openmct:openmct /opt/openmct /opt/nvm

ENV HOME=/opt/openmct
USER ${SERVICE_UID}:${SERVICE_GID}

# Default entrypoint (missions override via volume mount)
COPY entrypoint.sh /entrypoint.sh

#--- OCI IMAGE LABELS (set at build time to avoid cache busting earlier layers)
ARG OCI_SOURCE=""
ARG OCI_REVISION=""
ARG OCI_CREATED=""
ARG OCI_TITLE="openmct"
ARG OCI_VENDOR=""
ARG BUILD_HOST=""

ENV BUILD_HOST=${BUILD_HOST}

LABEL org.opencontainers.image.source="${OCI_SOURCE}" \
      org.opencontainers.image.revision="${OCI_REVISION}" \
      org.opencontainers.image.created="${OCI_CREATED}" \
      org.opencontainers.image.title="${OCI_TITLE}" \
      org.opencontainers.image.vendor="${OCI_VENDOR}" \
      org.opencontainers.image.build.host="${BUILD_HOST}"

CMD ["/entrypoint.sh"]
