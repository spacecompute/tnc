FROM maven:3.9.9-eclipse-temurin-17

#--- PROXY CONFIG (if needed)
ARG MAVEN_HTTPS_PROXY
ARG HTTPS_PROXY
ARG HTTP_PROXY
ARG NO_PROXY
ARG DEPLOYMENT_ENVIRO

ENV MAVEN_HTTPS_PROXY=${MAVEN_HTTPS_PROXY}
ENV HTTPS_PROXY=${HTTPS_PROXY}
ENV HTTP_PROXY=${HTTP_PROXY}
ENV NO_PROXY=${NO_PROXY}
ENV DEPLOYMENT_ENVIRO=${DEPLOYMENT_ENVIRO}

RUN apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y --no-install-recommends \
        netcat-traditional netcat-openbsd iputils-ping \
        git jq tmux tree vim less curl wget ca-certificates tar gzip gosu acl && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

#--- Specifics
ARG GIT_URL=https://github.com/yamcs/jsle.git
ARG GIT_COMMIT=master

ENV GIT_URL=${GIT_URL}
ENV GIT_COMMIT=${GIT_COMMIT}

WORKDIR /opt

RUN git clone -b ${GIT_COMMIT} --recurse-submodules ${GIT_URL}

WORKDIR /opt/jsle

# Maven settings (stub by default, proxy settings for restricted environments)
COPY settings.xm[l] /opt/jsle/
RUN test -f /opt/jsle/settings.xml || \
    echo "<settings><proxies></proxies></settings>" > /opt/jsle/settings.xml

# Override vulnerable transitive deps pinned by upstream jsle
# CRITICAL:
#   maven-shared-utils 3.2.1   → CVE-2022-29599 (stale cache from Maven plugins)
#   maven-core 2.0.6/3.0       → CVE-2021-26291 (stale cache from Maven plugins)
#   plexus-utils 1.5.8/2.0.4   → CVE-2017-1000487 (stale cache from Maven plugins)
# HIGH:
#   io.netty 4.1.130           → CVE-2026-42583, CVE-2026-44249, CVE-2026-45416,
#                                 CVE-2026-50010
#   commons-io 2.5/2.11.0      → CVE-2024-47554 (stale cache from Maven plugins)
#   plexus-utils 1.5.8/2.0.4   → CVE-2022-4244, CVE-2025-67030 (stale cache)
#   plexus-utils 3.5.1         → CVE-2025-67030 (stale cache from Maven plugins)
# NOT OVERRIDDEN:
#   plexus-utils 3.5.1          → CVE-2025-67030
#     shipped in /usr/share/maven/lib/ by the maven:3.9.9-eclipse-temurin-17 base
#     image; cannot be removed without breaking Maven itself
RUN sed -i 's|<version>4.1.130.Final</version>|<version>4.1.135.Final</version>|' /opt/jsle/pom.xml

# Compile and resolve dependencies, then purge vulnerable cached jars — all in one layer
RUN mvn ${MAVEN_HTTPS_PROXY} compile -DskipTests && \
    rm -rf /root/.m2/repository/org/apache/maven/shared/maven-shared-utils/3.2.1 \
           /root/.m2/repository/org/apache/maven/maven-core/2.0.6 \
           /root/.m2/repository/org/apache/maven/maven-core/3.0 \
           /root/.m2/repository/org/codehaus/plexus/plexus-utils/1.5.8 \
           /root/.m2/repository/org/codehaus/plexus/plexus-utils/2.0.4 \
           /root/.m2/repository/org/codehaus/plexus/plexus-utils/3.5.1 \
           /root/.m2/repository/commons-io/commons-io/2.5 \
           /root/.m2/repository/commons-io/commons-io/2.11.0 \
           /root/.m2/repository/io/netty/*/4.1.130.Final

#--- SHARED GROUP (cross-service volume access; name from mission, GID always 10000)
ARG MISSION_SC=mission-sc
ARG SHARED_GID=10000

RUN if getent group ${SHARED_GID} >/dev/null 2>&1; then \
        groupmod -n ${MISSION_SC} $(getent group ${SHARED_GID} | cut -d: -f1); \
    else \
        groupadd -r -g ${SHARED_GID} ${MISSION_SC}; \
    fi

ENV SHARED_GID=${SHARED_GID}

#--- SERVICE USER (override UID/GID at build time to match host or orchestrator)
ARG SERVICE_UID=10004
ARG SERVICE_GID=10004

ENV SERVICE_UID=${SERVICE_UID}
ENV SERVICE_GID=${SERVICE_GID}

RUN groupadd -r -g ${SERVICE_GID} jsle && \
    useradd -r -u ${SERVICE_UID} -g jsle -G ${MISSION_SC} -d /opt/jsle -s /sbin/nologin jsle && \
    mkdir -p /opt/jsle /storage/data1 && \
    chown -R jsle:jsle /opt/jsle /storage/data1

ENV HOME=/opt/jsle
ENV MAVEN_CONFIG=/opt/jsle/.m2
USER ${SERVICE_UID}:${SERVICE_GID}

# Default entrypoint (missions override via volume mount)
COPY entrypoint.sh /entrypoint.sh

#--- OCI IMAGE LABELS (set at build time to avoid cache busting earlier layers)
ARG OCI_SOURCE=""
ARG OCI_REVISION=""
ARG OCI_CREATED=""
ARG OCI_TITLE="sle"
ARG OCI_VENDOR=""
ARG BUILD_HOST=""

ENV BUILD_HOST=${BUILD_HOST}

LABEL org.opencontainers.image.source="${OCI_SOURCE}" \
      org.opencontainers.image.revision="${OCI_REVISION}" \
      org.opencontainers.image.created="${OCI_CREATED}" \
      org.opencontainers.image.title="${OCI_TITLE}" \
      org.opencontainers.image.vendor="${OCI_VENDOR}" \
      org.opencontainers.image.build.host="${BUILD_HOST}"

CMD ["/entrypoint.sh"]
