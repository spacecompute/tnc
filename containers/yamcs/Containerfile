FROM maven:3.9.9-eclipse-temurin-17

#--- PROXY CONFIG (if needed)
ARG MAVEN_HTTPS_PROXY
ARG HTTPS_PROXY
ARG HTTP_PROXY
ARG NO_PROXY
ARG DEPLOYMENT_ENVIRO

ENV MAVEN_HTTPS_PROXY=${MAVEN_HTTPS_PROXY}
ENV HTTPS_PROXY=${HTTPS_PROXY}
ENV HTTP_PROXY=${HTTP_PROXY}
ENV NO_PROXY=${NO_PROXY}
ENV DEPLOYMENT_ENVIRO=${DEPLOYMENT_ENVIRO}

ARG GIT_URL=https://github.com/yamcs/yamcs/
ARG GIT_COMMIT=master

ENV GIT_URL=${GIT_URL}
ENV GIT_COMMIT=${GIT_COMMIT}

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        netcat-traditional netcat-openbsd iputils-ping \
        git jq tmux tree vim less curl wget ca-certificates gosu acl && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /opt

# Clone yamcs to get a base pom.xml for dependency resolution
RUN git clone -b ${GIT_COMMIT} --recurse-submodules ${GIT_URL}

WORKDIR /opt/yamcs

# Maven settings (stub by default, proxy settings for restricted environments)
COPY settings.xm[l] /opt/yamcs/
RUN test -f /opt/yamcs/settings.xml || \
    echo "<settings><proxies></proxies></settings>" > /opt/yamcs/settings.xml

# Compile and resolve dependencies (exec:java handles classpath via Maven)
RUN mvn ${MAVEN_HTTPS_PROXY} compile -DskipTests -Dmaven.repo.local=/opt/yamcs/.m2/repository

#--- SHARED GROUP (cross-service volume access; name from mission, GID always 10000)
ARG MISSION_SC=mission-sc
ARG SHARED_GID=10000

RUN if getent group ${SHARED_GID} >/dev/null 2>&1; then \
        groupmod -n ${MISSION_SC} $(getent group ${SHARED_GID} | cut -d: -f1); \
    else \
        groupadd -r -g ${SHARED_GID} ${MISSION_SC}; \
    fi

ENV SHARED_GID=${SHARED_GID}

#--- SERVICE USER (override UID/GID at build time to match host or orchestrator)
ARG SERVICE_UID=10001
ARG SERVICE_GID=10001

ENV SERVICE_UID=${SERVICE_UID}
ENV SERVICE_GID=${SERVICE_GID}

RUN groupadd -r -g ${SERVICE_GID} yamcs && \
    useradd -r -u ${SERVICE_UID} -g yamcs -G ${MISSION_SC} -d /opt/yamcs -s /sbin/nologin yamcs && \
    mkdir -p /opt/yamcs/src/main/yamcs/mdb \
             /opt/yamcs/src/main/yamcs/etc \
             /opt/yamcs/src/main/yamcs/incoming \
             /opt/yamcs/src/main/yamcs/displays \
             /opt/yamcs/src/main/yamcs/functions \
             /opt/yamcs/src/main/resources/META-INF/services \
             /opt/yamcs/src/main/java/com/example/myproject \
             /opt/yamcs/target \
             /opt/yamcs/scripts && \
    chown -R yamcs:yamcs /opt/yamcs

ENV HOME=/opt/yamcs
ENV MAVEN_CONFIG=/opt/yamcs/.m2
USER ${SERVICE_UID}:${SERVICE_GID}

# Default entrypoint (missions override via volume mount)
COPY entrypoint.sh /entrypoint.sh

#--- OCI IMAGE LABELS (set at build time to avoid cache busting earlier layers)
ARG OCI_SOURCE=""
ARG OCI_REVISION=""
ARG OCI_CREATED=""
ARG OCI_TITLE="yamcs"
ARG OCI_VENDOR=""
ARG BUILD_HOST=""

ENV BUILD_HOST=${BUILD_HOST}

LABEL org.opencontainers.image.source="${OCI_SOURCE}" \
      org.opencontainers.image.revision="${OCI_REVISION}" \
      org.opencontainers.image.created="${OCI_CREATED}" \
      org.opencontainers.image.title="${OCI_TITLE}" \
      org.opencontainers.image.vendor="${OCI_VENDOR}" \
      org.opencontainers.image.build.host="${BUILD_HOST}"

CMD ["/entrypoint.sh"]
