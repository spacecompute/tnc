FROM maven:3.9.9-eclipse-temurin-17

#--- PROXY CONFIG (if needed)
ARG MAVEN_HTTPS_PROXY
ARG HTTPS_PROXY
ARG HTTP_PROXY
ARG NO_PROXY
ARG DEPLOYMENT_ENVIRO

ENV MAVEN_HTTPS_PROXY=${MAVEN_HTTPS_PROXY}
ENV HTTPS_PROXY=${HTTPS_PROXY}
ENV HTTP_PROXY=${HTTP_PROXY}
ENV NO_PROXY=${NO_PROXY}
ENV DEPLOYMENT_ENVIRO=${DEPLOYMENT_ENVIRO}

RUN apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y --no-install-recommends \
        netcat-traditional netcat-openbsd iputils-ping \
        git jq tmux tree vim less curl wget ca-certificates tar gzip gosu acl && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

#--- Specifics
ARG GIT_URL=https://github.com/yamcs/quickstart
ARG GIT_COMMIT=master

ENV GIT_URL=${GIT_URL}
ENV GIT_COMMIT=${GIT_COMMIT}

WORKDIR /opt

# Clone quickstart, keep only pom.xml and Maven project structure
RUN git clone -b ${GIT_COMMIT} --depth 1 ${GIT_URL} yamcs-orig

WORKDIR /opt/yamcs

# Selective copy — only what's needed for build
RUN cp /opt/yamcs-orig/pom.xml .

# Add Jython for STOL function scripts (default for all missions)
RUN sed -i '/<\/dependencies>/i \
    <!-- Jython for STOL function scripts -->\
    <dependency>\
      <groupId>org.python<\/groupId>\
      <artifactId>jython-standalone<\/artifactId>\
      <version>2.7.4<\/version>\
    <\/dependency>' /opt/yamcs/pom.xml

# Override netty transitive dependency via BOM import (CVE remediation)
# Replaces per-jar sed+delete approach with proper Maven dependency management
#   io.netty 4.1.130 → CVE-2026-42583, CVE-2026-33870, CVE-2026-42584,
#                       CVE-2026-42587, CVE-2026-44249, CVE-2026-45416,
#                       CVE-2026-50010
RUN sed -i '/<dependencies>/i \
  <dependencyManagement><dependencies>\
    <dependency><groupId>io.netty<\/groupId><artifactId>netty-bom<\/artifactId>\
    <version>4.1.135.Final<\/version><type>pom<\/type><scope>import<\/scope><\/dependency>\
  <\/dependencies><\/dependencyManagement>' /opt/yamcs/pom.xml

# Maven settings (stub by default, proxy settings for restricted environments)
COPY settings.xm[l] /opt/yamcs/
RUN test -f /opt/yamcs/settings.xml || \
    echo "<settings><proxies></proxies></settings>" > /opt/yamcs/settings.xml

# Build distribution (bin/yamcsd + lib/*.jar), extract, clean up build artifacts
# Maven .m2 cache is kept for optional runtime decoder compilation
RUN mkdir -p src/main/java src/main/resources/META-INF/services && \
    mvn ${MAVEN_HTTPS_PROXY} package yamcs:bundle -DskipTests \
        -Dmaven.repo.local=/opt/yamcs/.m2/repository && \
    tar xzf target/*.tar.gz --strip-components=1 -C /opt/yamcs/ && \
    chmod +x /opt/yamcs/bin/* && \
    rm -rf target src && \
    rm -rf /opt/yamcs/.m2/repository/com/google/protobuf/protobuf-java/3.19.6 \
           /opt/yamcs/.m2/repository/commons-io/commons-io/2.11.0 \
           /opt/yamcs/.m2/repository/commons-io/commons-io/2.13.0 \
           /opt/yamcs/.m2/repository/org/codehaus/plexus/plexus-utils/3.4.2 \
           /opt/yamcs/.m2/repository/org/codehaus/plexus/plexus-utils/3.5.1 \
           /opt/yamcs/.m2/repository/org/codehaus/plexus/plexus-utils/4.0.0 \
           /opt/yamcs/.m2/repository/org/codehaus/plexus/plexus-utils/4.0.2

#--- SHARED GROUP (cross-service volume access; name from mission, GID always 10000)
ARG MISSION_SC=mission-sc
ARG SHARED_GID=10000

RUN if getent group ${SHARED_GID} >/dev/null 2>&1; then \
        groupmod -n ${MISSION_SC} $(getent group ${SHARED_GID} | cut -d: -f1); \
    else \
        groupadd -r -g ${SHARED_GID} ${MISSION_SC}; \
    fi

ENV SHARED_GID=${SHARED_GID}

#--- SERVICE USER (override UID/GID at build time to match host or orchestrator)
ARG SERVICE_UID=10001
ARG SERVICE_GID=10001

ENV SERVICE_UID=${SERVICE_UID}
ENV SERVICE_GID=${SERVICE_GID}

RUN groupadd -r -g ${SERVICE_GID} yamcs && \
    useradd -r -u ${SERVICE_UID} -g yamcs -G ${MISSION_SC} -d /opt/yamcs -s /sbin/nologin yamcs && \
    mkdir -p /opt/yamcs/etc \
             /opt/yamcs/mdb \
             /opt/yamcs/incoming \
             /opt/yamcs/displays \
             /opt/yamcs/functions \
             /opt/yamcs/scripts \
             /opt/yamcs/decoders \
             /opt/yamcs/yamcs-data \
             /opt/yamcs/cache \
             /opt/yamcs/log \
             /opt/yamcs/var/run \
             /opt/yamcs/lib/ext && \
    chown -R yamcs:yamcs /opt/yamcs

ENV HOME=/opt/yamcs
ENV MAVEN_CONFIG=/opt/yamcs/.m2
USER ${SERVICE_UID}:${SERVICE_GID}

# Default entrypoint (missions override via volume mount)
COPY entrypoint.sh /entrypoint.sh

#--- OCI IMAGE LABELS (set at build time to avoid cache busting earlier layers)
ARG OCI_SOURCE=""
ARG OCI_REVISION=""
ARG OCI_CREATED=""
ARG OCI_TITLE="yamcs"
ARG OCI_VENDOR=""
ARG BUILD_HOST=""

ENV BUILD_HOST=${BUILD_HOST}

LABEL org.opencontainers.image.source="${OCI_SOURCE}" \
      org.opencontainers.image.revision="${OCI_REVISION}" \
      org.opencontainers.image.created="${OCI_CREATED}" \
      org.opencontainers.image.title="${OCI_TITLE}" \
      org.opencontainers.image.vendor="${OCI_VENDOR}" \
      org.opencontainers.image.build.host="${BUILD_HOST}"

CMD ["/entrypoint.sh"]
