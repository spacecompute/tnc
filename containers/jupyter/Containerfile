FROM quay.io/jupyterhub/jupyterhub:5

#--- PROXY CONFIG (if needed)
ARG MAVEN_HTTPS_PROXY
ARG HTTPS_PROXY
ARG HTTP_PROXY
ARG NO_PROXY
ARG DEPLOYMENT_ENVIRO

ENV MAVEN_HTTPS_PROXY=${MAVEN_HTTPS_PROXY}
ENV HTTPS_PROXY=${HTTPS_PROXY}
ENV HTTP_PROXY=${HTTP_PROXY}
ENV NO_PROXY=${NO_PROXY}
ENV DEPLOYMENT_ENVIRO=${DEPLOYMENT_ENVIRO}

RUN apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y --no-install-recommends \
        netcat-traditional netcat-openbsd iputils-ping \
        git jq tmux tree vim less curl wget ca-certificates tar gzip gosu acl && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

#--- Specifics
# System runtimes and dev libraries for additional kernels
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        libzmq3-dev libffi-dev libcurl4-openssl-dev libssl-dev build-essential \
        ruby ruby-dev \
        perl cpanminus \
        gnuplot ghostscript \
        r-base r-base-dev \
        octave && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Pip-installable kernel packages
RUN pip install --no-cache-dir \
    gnuplot_kernel \
    octave_kernel

# Ruby kernel (register to system prefix so JupyterHub users can see it)
RUN gem install iruby && \
    iruby register --force && \
    mkdir -p /usr/local/share/jupyter/kernels && \
    cp -r /root/.local/share/jupyter/kernels/ruby3 /usr/local/share/jupyter/kernels/

# Perl kernel (register to system prefix)
RUN cpanm --notest Devel::IPerl && \
    iperl --version && \
    mkdir -p /usr/local/share/jupyter/kernels/iperl && \
    echo '{"display_name":"Perl","language":"perl","argv":["iperl","kernel","{connection_file}"]}' \
        > /usr/local/share/jupyter/kernels/iperl/kernel.json

# R kernel (user=FALSE installs system-wide)
RUN R --slave -e "install.packages('IRkernel', repos='https://cloud.r-project.org'); IRkernel::installspec(user=FALSE)"

# Gnuplot kernel registration (--sys-prefix for system-wide)
RUN python -m gnuplot_kernel install --sys-prefix

# Octave kernel registration (--sys-prefix for system-wide)
RUN python -m octave_kernel install --sys-prefix

# Core infrastructure (baked into image)
RUN pip install --no-cache-dir \
    jupyterlab \
    jupyter-collaboration \
    jupyterhub-idle-culler

# Science/data packages
COPY requirements.txt /tmp/requirements.txt
RUN if [ -f /tmp/requirements.txt ]; then \
        pip install --no-cache-dir -r /tmp/requirements.txt; \
    fi && rm -f /tmp/requirements.txt

# Remove build-time dev packages and compiler toolchain (all pull in linux-libc-dev CVEs)
RUN apt-get purge -y --auto-remove \
        build-essential gcc g++ make \
        libzmq3-dev libffi-dev libcurl4-openssl-dev libssl-dev \
        ruby-dev r-base-dev && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/jupyter

# Default config (missions override via volume mount)
COPY jupyterhub_config.py /opt/jupyter/jupyterhub_config.py

#--- SHARED GROUP (cross-service volume access; name from mission, GID always 10000)
ARG MISSION_SC=mission-sc
ARG SHARED_GID=10000

RUN if getent group ${SHARED_GID} >/dev/null 2>&1; then \
        groupmod -n ${MISSION_SC} $(getent group ${SHARED_GID} | cut -d: -f1); \
    else \
        groupadd -r -g ${SHARED_GID} ${MISSION_SC}; \
    fi

ENV SHARED_GID=${SHARED_GID}

#--- SERVICE USER (override UID/GID at build time to match host or orchestrator)
ARG SERVICE_UID=10003
ARG SERVICE_GID=10003

ENV SERVICE_UID=${SERVICE_UID}
ENV SERVICE_GID=${SERVICE_GID}

RUN groupadd -r -g ${SERVICE_GID} jupyter && \
    useradd -r -u ${SERVICE_UID} -g jupyter -G ${MISSION_SC} -d /opt/jupyter -s /sbin/nologin jupyter && \
    mkdir -p /opt/jupyter /srv/procedures /srv/lib && \
    chown -R jupyter:jupyter /opt/jupyter /srv/procedures /srv/lib

ENV HOME=/opt/jupyter
USER ${SERVICE_UID}:${SERVICE_GID}

# Default entrypoint (missions override via volume mount)
COPY entrypoint.sh /entrypoint.sh

#--- OCI IMAGE LABELS (set at build time to avoid cache busting earlier layers)
ARG OCI_SOURCE=""
ARG OCI_REVISION=""
ARG OCI_CREATED=""
ARG OCI_TITLE="jupyter"
ARG OCI_VENDOR=""
ARG BUILD_HOST=""

ENV BUILD_HOST=${BUILD_HOST}

LABEL org.opencontainers.image.source="${OCI_SOURCE}" \
      org.opencontainers.image.revision="${OCI_REVISION}" \
      org.opencontainers.image.created="${OCI_CREATED}" \
      org.opencontainers.image.title="${OCI_TITLE}" \
      org.opencontainers.image.vendor="${OCI_VENDOR}" \
      org.opencontainers.image.build.host="${BUILD_HOST}"

CMD ["/entrypoint.sh"]
